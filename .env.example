# Copy this file to `.env.local` (local dev) or set these as environment
# variables in your host (e.g. Vercel → Project → Settings → Environment
# Variables). Never commit `.env.local` — it is gitignored.

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
# New-style publishable key (sb_publishable_...). Safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy anon JWT is also accepted if you prefer:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Cloudinary (image hosting) ---
# Cloud name is public/safe. Preset is used for unsigned uploads (fallback).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=nesty_unsigned
# Server-only credentials used to SIGN uploads in /api/cloudinary-sign.
# These MUST NOT be prefixed with NEXT_PUBLIC (never sent to the browser).
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- AI assistant (server-only; every call is proxied through /api/assistant) ---
# These are NOT prefixed with NEXT_PUBLIC — the key stays on the server and never
# reaches the browser. They MUST be set in your host (Vercel → Project → Settings
# → Environment Variables) for the assistant to work in PRODUCTION. Without
# AI_ASSISTANT_API_KEY the server returns a "config" error and the assistant shows
# as unavailable — this is the #1 reason the AI "works locally but not deployed".
# Copy the exact values from your local .env.local so prod matches dev.
AI_ASSISTANT_ENABLED=true
AI_ASSISTANT_PROVIDER=gemini
AI_ASSISTANT_API_KEY=
AI_ASSISTANT_MODEL=gemini-3.1-flash-lite
AI_ASSISTANT_FALLBACK_MODEL=gemini-flash-lite-latest
AI_ASSISTANT_BASE_URL=https://generativelanguage.googleapis.com/v1beta
